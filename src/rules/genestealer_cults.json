  "abilities": {
    "id": "abilities",
    "title": "Ability",
    "pick": 1,
    "options": [
      {
        "id": "blessed_venom",
        "name": "Blessed Venom",
        "text": "Melee weapons equipped by models in this unit have the [ANTI-INFANTRY 3+] ability."
      },
      {
        "id": "elusive",
        "name": "Elusive",
        "text": "Once per turn, when an enemy unit ends a Normal, Advance or Fall Back move within 9\" of this model, if this model is not part of an Attached unit and is not within Engagement Range, it can make a Normal move up to 6\"."
      },
      {
        "id": "insidious_evasion",
        "name": "Insidious Evasion",
        "text": "At the end of your opponent's Fight phase, if this unit is not within Engagement Range of enemy units, once per battle you may remove this unit from the battlefield and place it into Strategic Reserves."
      },
      {
        "id": "psychic_spore",
        "name": "Psychic Spore",
        "text": "At the start of the first battle round select one enemy unit to be this model's prey. Each time this model makes an attack that targets that unit you can re-roll the Hit roll and the Wound roll."
      },
      {
        "id": "shadow_killer",
        "name": "Shadow Killer",
        "text": "If this model is not part of an Attached unit and is equipped with no ranged weapons (excluding pistols), enemy units cannot use Fire Overwatch to shoot at this model."
      },
      {
        "id": "spiritual_leader",
        "name": "Spiritual Leader",
        "text": "Once per battle, at the start of any phase, select one friendly Genestealer Cults unit that is Battle-shocked and within 12\". That unit is no longer Battle-shocked."
      },
      {
        "id": "twisted_science",
        "name": "Twisted Science",
        "text": "While this model is leading a unit, melee weapons equipped by models in that unit have the [LETHAL HITS] ability."
      },
      {
        "id": "voice_of_new_truths",
        "name": "Voice of New Truths",
        "text": "In your Command phase, one model from your army with this ability can use it. If it does, select one enemy unit within 18\". That enemy unit must take a Battle-shock test."
      }
    ]
  },
