    "id": "specialisms",
    "title": "Specialisms",
    "pick": 1,
    "options": [
      {
        "id": "dirtcycle",
        "name": "Dirtcycle",
        "text": "Change this model's Move characteristic to 12\", its Toughness characteristic to 4, remove the INFANTRY keyword and add the MOUNTED keyword. Remove Deep Strike and Infiltrators abilities (if applicable). It gains Scouts 9\" and Stealth. Replace the list of units this model can be attached to with ATALAN JACKALS.",
        "points": 0,
        "effects": [
          {
            "kind": "set",
            "field": "move",
            "value": 12
          },
          {
            "kind": "set",
            "field": "toughness",
            "value": 4
          },
          {
            "kind": "remove",
            "field": "keywords",
            "value": "Infantry"
          },
          {
