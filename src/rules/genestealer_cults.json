            "value": ["Mounted", "Scouts 9\"", "Stealth"]
          },
          {
            "kind": "setLeaderUnits",
            "value": ["Atalan Jackals"]
          }
        ]
      },
      {
        "id": "shepherd_of_the_blessed",
        "name": "Shepherd of the Blessed",
        "text": "Replace the list of units this model can be attached to: ABERRANTS.",
        "points": 0,
